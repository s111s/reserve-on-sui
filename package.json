{
  "name": "agentic-booking",
  "version": "0.1.0",
  "description": "Reserve-with-Google × Sui zkLogin Booking System — Hackathon Boilerplate",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "tsx src/server/index.ts",
    "move:build": "sui move build --path src/contracts",
    "move:test": "sui move test --path src/contracts",
    "move:publish": "sui client publish --gas-budget 100000000 src/contracts",
    "server:test": "TEST_MODE=true tsx src/server/index.ts",
    "test:api": "TEST_MODE=true tsx src/tests/api.test.ts",
    "test:all": "TEST_MODE=true concurrently -k -s first -n server,test \"tsx src/server/index.ts\" \"wait-on http://localhost:3001/api/health && tsx src/tests/api.test.ts\""
  },
  "dependencies": {
    "@mysten/dapp-kit": "^0.14.0",
    "@mysten/enoki": "^0.4.0",
    "@mysten/sui": "^1.21.0",
    "@tanstack/react-query": "^5.62.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "jose": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
