# ============================================================
#  Agentic Booking — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
#
#  Sharing secrets with teammates (production / GCP):
#    Recommended: Google Secret Manager
#      gcloud secrets create <SECRET_NAME> --replication-policy="automatic"
#      echo -n "value" | gcloud secrets versions add <SECRET_NAME> --data-file=-
#    Then grant access:
#      gcloud secrets add-iam-policy-binding <SECRET_NAME> \
#        --member="user:teammate@gmail.com" \
#        --role="roles/secretmanager.secretAccessor"
#    Alternative (simple): shared vault in 1Password or Bitwarden
#
#  Variables marked [SECRET] must go into Secret Manager or a password vault.
#  Variables marked [PUBLIC] are safe to share / commit in non-.env files.
# ============================================================

# ── Sui Network ─────────────────────────────────────────────
VITE_SUI_NETWORK=testnet

# ── Move Contract (deployed on VITE_SUI_NETWORK) ────────────
VITE_PACKAGE_ID=
# Original v1 package ID — coin types are pinned to the package that first published them
# If you have never upgraded the package, this equals VITE_PACKAGE_ID
VITE_COIN_PACKAGE_ID=
VITE_POINTS_LEDGER_ID=
VITE_TIER_REGISTRY_ID=
VITE_TIER_CONFIG_ID=

# Object IDs owned by the deployer address (SUI_SPONSOR_PRIVATE_KEY)
ADMIN_CAP_ID=
OPERATOR_CAP_ID=

# Platform fee receiver address
VITE_FEE_RECEIVER_ADDRESS=

# ── Mock stablecoin faucets (testnet only) ───────────────────
USDC_TREASURY_CAP_ID=
USDT_TREASURY_CAP_ID=
SUIUSD_TREASURY_CAP_ID=

# ── Auth ────────────────────────────────────────────────────
# Google OAuth Client ID — for zkLogin (Sign in with Google)
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Add <APP_BASE_URL>/auth/callback to Authorized redirect URIs
VITE_GOOGLE_CLIENT_ID=

# ── Server ──────────────────────────────────────────────────
PORT=3001

# Base URL of this app — used to build payment_url sent to teammate
APP_BASE_URL=http://localhost:5173

# [SECRET] zkLogin salt derivation secret — MUST stay stable after first user login
# Changing this invalidates all existing zkLogin wallet addresses
SALT_SECRET=

# [SECRET] Deployer private key (hex, no 0x prefix) — must hold AdminCap + OperatorCap
# Used for: gas sponsorship, tier claims, on-chain point deductions
SUI_SPONSOR_PRIVATE_KEY=

# [SECRET] Shinami gas station + wallet API keys (server-side only — never expose to frontend)
# https://app.shinami.com → create keys for testnet
SHINAMI_GAS_KEY=
SHINAMI_WALLET_KEY=

# ── Inter-service callback ──────────────────────────────────
# Your teammate's server URL — receives PaymentStatus POST after each booking
# Leave empty to skip forwarding (useful for local dev)
CALLBACK_URL=

# Optional: Aappoint proxy token (leave empty for unauthenticated GET)
AAPPOINT_API_TOKEN=
